{
  "name": "laneos",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "build:web": "npm run build --workspace=web",
    "dev:mobile": "npm run start --workspace=mobile",
    "lint": "npm run lint --workspace=web",
    "db:test": "node scripts/test-connection.mjs",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "db:seed": "node scripts/seed-supabase.mjs"
  }
}
